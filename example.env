# Browser-safe values from Supabase Dashboard > Connect.
# Never put a personal access token, secret key, or service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Use "supabase" for deployed login and protected portal data.
# Set "demo" only when intentionally using local mock data.
VITE_DATA_SOURCE=supabase

# Codex / Supabase MCP only. Store this in your Windows user environment,
# never in this file or any VITE_ variable:
# SUPABASE_ACCESS_TOKEN=sbp_your-personal-access-token
